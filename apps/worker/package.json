{
  "name": "@vaultbridge/worker",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit && prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "tsx --test tests/*.test.ts",
    "build": "wrangler deploy --dry-run --outdir .wrangler/tmp/bundle",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.4.5",
    "wrangler": "^4.0.0"
  }
}
