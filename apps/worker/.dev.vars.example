# Required Worker configuration. Never commit real values.
GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=your-private-notes-repository
GITHUB_BRANCH=main
MAX_FILE_BYTES=20971520

# Secrets. GITHUB_TOKEN should only grant the selected notes repository
# Contents read/write. Generate SYNC_TOKEN with: openssl rand -base64 32
GITHUB_TOKEN=replace-with-a-fine-grained-github-token
SYNC_TOKEN=replace-with-a-random-sync-token
