{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vaultbridge",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "vars": {
    "GITHUB_OWNER": "your-github-user-or-org",
    "GITHUB_REPO": "your-vault-repo",
    "GITHUB_BRANCH": "main",
    "MAX_FILE_BYTES": "20971520"
  }
}
